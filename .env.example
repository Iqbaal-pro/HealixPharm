# ============================================================
# HealixPharm – Environment Variables EXAMPLE
# Copy this file, rename it to .env, and fill in real values.
# Get real credentials from your team lead privately.
# ============================================================

# ─── Railway Database (single DB for ALL services) ──────────
DB_USER=root
DB_PASSWORD=YOUR_RAILWAY_DB_PASSWORD
DB_HOST=YOUR_RAILWAY_DB_HOST
DB_PORT=33283
DB_NAME=railway

# ─── AWS S3 (Prescription image uploads) ────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=healix-prescriptions
AWS_REGION=us-east-1

# ─── Main Database (healix_app) ─────────────────────────────
DB_HOST=ballast.proxy.rlwy.net
DB_PORT=33283
DB_USER=root
DB_PASSWORD=RlnRjwychOZnxtmmsQijKtvjmuadwelv
DB_NAME=railway

# Stock DB = same as main DB now
STOCK_DB_HOST=ballast.proxy.rlwy.net
STOCK_DB_PORT=33283
STOCK_DB_USER=root
STOCK_DB_PASSWORD=RlnRjwychOZnxtmmsQijKtvjmuadwelv
STOCK_DB_NAME=railway


# ─── User Management Database ───────────────────────────────
USER_DB_USER=stock_user
USER_DB_PASSWORD=stock123
USER_DB_HOST=127.0.0.1
USER_DB_PORT=3306
USER_DB_NAME=user_management

# ─── Auth Token ─────────────────────────────────────────────
AUTH_SECRET_KEY=change-this-secret

# ─── Refill Reminder ────────────────────────────────────────
REFILL_THRESHOLD=3

# ─── Auth ────────────────────────────────────────────────────
AUTH_SECRET_KEY=change-this-to-a-strong-secret

# ─── PayHere Online Payment ──────────────────────────────────
PAYHERE_MERCHANT_ID=YOUR_MERCHANT_ID
PAYHERE_MERCHANT_SECRET=YOUR_MERCHANT_SECRET
PAYHERE_NOTIFY_URL=https://your-domain.com/payments/payhere/notify
PAYHERE_SANDBOX=True
PAYHERE_CURRENCY=LKR
