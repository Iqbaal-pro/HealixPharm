# ============================================================
# HealixPharm – Combined Environment Variables
# Copy this file to .env and fill in your real values.
# Each backend service also has its own .env for overrides.
# ============================================================

# ─── Twilio (WhatsApp & SMS) ─────────────────────────────────
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_WEBHOOK_TOKEN=YOUR_WEBHOOK_TOKEN
TWILIO_SMS_FROM_NUMBER=+1234567890

# ─── AWS S3 (Prescription uploads) ──────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=healix-prescriptions
AWS_REGION=us-east-1

# ─── Main Database (healix_app) ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=healix

# ─── Stock Management Database ──────────────────────────────
STOCK_DB_USER=stock_user
STOCK_DB_PASSWORD=stock123
STOCK_DB_HOST=127.0.0.1
STOCK_DB_PORT=3306
STOCK_DB_NAME=stock_management_db

# ─── User Management Database ───────────────────────────────
USER_DB_USER=stock_user
USER_DB_PASSWORD=stock123
USER_DB_HOST=127.0.0.1
USER_DB_PORT=3306
USER_DB_NAME=user_management

# ─── Auth Token ─────────────────────────────────────────────
AUTH_SECRET_KEY=change-this-secret

# ─── Refill Reminder ────────────────────────────────────────
REFILL_THRESHOLD=3
SMS_SIMULATE=true

# ─── Disease Alert System ───────────────────────────────────
ALERT_JOB_INTERVAL_DAYS=7
ALERT_SUCCESS_THRESHOLD=0.90
ALERT_MIN_THREAT_LEVEL=High
ALERT_MESSAGE_TEMPLATE=ALERT: {disease_name} in {region}. Threat: {threat_level}. Take precautions. Source: MOH

# ─── PayHere Online Payment ─────────────────────────────────
PAYHERE_MERCHANT_ID=YOUR_MERCHANT_ID
PAYHERE_MERCHANT_SECRET=YOUR_MERCHANT_SECRET
PAYHERE_NOTIFY_URL=https://your-domain.com/payments/payhere/notify
PAYHERE_SANDBOX=True
PAYHERE_CURRENCY=LKR


