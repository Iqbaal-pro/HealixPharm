# Example env file for HealixPharm (do NOT commit secrets to public repos)
# Using Twilio WhatsApp API instead of Meta

# Twilio WhatsApp (main communication)
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_WEBHOOK_TOKEN=YOUR_WEBHOOK_TOKEN

# Twilio SMS (fallback rejection notifications)
TWILIO_SMS_FROM_NUMBER=+1234567890

# AWS S3
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=healix-prescriptions
AWS_REGION=us-east-1

